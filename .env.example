# Application
APP_ENV=development
APP_URL=http://localhost:3147
ADMIN_EMAILS=admin@example.com
# Public Vercel URL. On Railway, keep this pointing to the Vercel frontend.
# BACKEND_URL is used by the Vercel build to proxy /api to Railway.
BACKEND_URL=

# Supabase PostgreSQL
# Use the transaction pooler URL (port 6543) in the running application.
SUPABASE_DATABASE_URL=
# Use the direct database URL (port 5432) only for migrations.
SUPABASE_DIRECT_URL=

# Billing provider: cakto or stripe
BILLING_PROVIDER=cakto

# Cakto checkout and webhook
CAKTO_WEBHOOK_SECRET=
CAKTO_PRO_MONTHLY_CHECKOUT_URL=
CAKTO_PRO_ANNUAL_CHECKOUT_URL=
CAKTO_TEAMS_MONTHLY_CHECKOUT_URL=
CAKTO_TEAMS_ANNUAL_CHECKOUT_URL=
CAKTO_PRO_MONTHLY_OFFER_ID=
CAKTO_PRO_ANNUAL_OFFER_ID=
CAKTO_TEAMS_MONTHLY_OFFER_ID=
CAKTO_TEAMS_ANNUAL_OFFER_ID=
CAKTO_PRO_PRODUCT_IDS=
CAKTO_TEAMS_PRODUCT_IDS=
CAKTO_CUSTOMER_PORTAL_URL=

# Transactional e-mail (Resend)
RESEND_API_KEY=
EMAIL_FROM=NexaCode AI <contato@example.com>

# Optional remote mentor. Without these values the verified local mentor remains active.
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_TEAMS_MONTHLY_PRICE_ID=
STRIPE_TEAMS_ANNUAL_PRICE_ID=
